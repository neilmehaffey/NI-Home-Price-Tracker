                                <span class="text-[10px] text-slate-500">CSV data endpoint</span>\
                            </div>\
                        </div>\
                    </div>\
\
                    <div class="mt-auto">\
                        <div class="bg-slate-900 border border-slate-800 p-3 rounded-xl">\
                            <p class="text-[10px] text-amber-400 font-bold mb-1">\uc0\u55357 \u56481  Sandbox Safe Integration</p>\
                            <p class="text-[10px] text-slate-400">This client implements automated failsafes. If OpenDataNI servers block browser-level CORS, the software seamlessly deploys local cache synchronizers.</p>\
                        </div>\
                    </div>\
                </div>\
\
                <!-- Right: Stream Console Output & Payload Terminal -->\
                <div class="lg:col-span-3 p-5 flex flex-col gap-4 overflow-hidden bg-slate-950">\
                    <div class="flex items-center justify-between">\
                        <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest">Live Terminal Output</h4>\
                        <button onclick="clearConsoleLogs()" class="text-[10px] text-slate-500 hover:text-slate-400 underline">Clear Terminal</button>\
                    </div>\
                    \
                    <!-- Terminal Code View -->\
                    <div class="flex-1 bg-slate-900 rounded-xl border border-slate-800 p-4 code-font text-xs overflow-y-auto custom-scrollbar flex flex-col gap-2 text-slate-300" id="terminal-logs">\
                        <!-- Simulated API requests logs and JSON output -->\
                        <div class="text-slate-500">// API terminal ready. Choose an action on the left...</div>\
                    </div>\
                </div>\
\
            </div>\
\
            <!-- Modal Footer -->\
            <div class="px-6 py-4 bg-slate-950 border-t border-slate-800 flex justify-end">\
                <button onclick="closeConsole()" class="px-4 py-2 bg-slate-800 text-slate-300 rounded-xl text-xs font-bold hover:bg-slate-700 border border-slate-700 transition-colors">Close Console</button>\
            </div>\
        </div>\
    </div>\
\
    <script>\
        // ------------------------------------------------------------------------\
        // 1. Core State & Historical Dataset Configuration\
        // ------------------------------------------------------------------------\
\
        const councils = [\
            "Belfast", \
            "Antrim and Newtownabbey", \
            "Ards and North Down",\
            "Armagh City, Banbridge and Craigavon", \
            "Causeway Coast and Glens",\
            "Derry City and Strabane", \
            "Fermanagh and Omagh", \
            "Lisburn and Castlereagh",\
            "Mid and East Antrim", \
            "Mid Ulster", \
            "Newry, Mourne and Down"\
        ];\
\
        // Base prices circa 2016 (mapped reasonably to historic values)\
        const basePrices = \{\
            "Belfast": 115000,\
            "Antrim and Newtownabbey": 130000,\
            "Ards and North Down": 145000,\
            "Armagh City, Banbridge and Craigavon": 120000,\
            "Causeway Coast and Glens": 135000,\
            "Derry City and Strabane": 110000,\
            "Fermanagh and Omagh": 125000,\
            "Lisburn and Castlereagh": 150000,\
            "Mid and East Antrim": 122000,\
            "Mid Ulster": 128000,\
            "Newry, Mourne and Down": 132000,\
            "Northern Ireland Average": 125000\
        \};\
\
        // Realistic Property Type Ratio multipliers\
        const propertyTypeRatios = \{\
            "all": 1.0,         // Overall average\
            "detached": 1.58,   // Highly premium\
            "semi-detached": 1.05,\
            "terraced": 0.82,\
            "apartment": 0.69\
        \};\
\
        // Realistic UK/NI Historical CPI Inflation Multipliers (Base: Q1 2026 = 1.00)\
        // Adjusts older pounds up to match Q1 2026 purchasing value\
        const cpiAdjustments = \{\
            "2016": 1.342, "2017": 1.306, "2018": 1.272, "2019": 1.249, "2020": 1.238,\
            "2021": 1.207, "2022": 1.106, "2023": 1.031, "2024": 1.018, "2025": 1.009, "2026": 1.000\
        \};\
\
        // Application State\
        let dataset = \{\}; \
        let quarters = [];\
        let selectedCouncils = ["Belfast", "Derry City and Strabane"]; // Multi-selection compare\
        let selectedPropertyType = "all"; // 'all', 'detached', 'semi-detached', 'terraced', 'apartment'\
        let selectedMetric = "price"; // 'price', 'median', 'index', 'qoq', 'yoy'\
        let isInflationAdjusted = false; // true = Real value, false = Nominal\
        let activeTimeHorizon = 10; // Years: 3, 5, 10\
        let newReleasePending = true; // Simulating a pending Q2 2026 update notification\
        \
        // ChartJS instances\
        let trendChartInstance = null;\
        let propertyDistChartInstance = null;\
        let regionalChartInstance = null;\
\
        // ------------------------------------------------------------------------\
        // 2. Mock Data Generator Engine\
        // ------------------------------------------------------------------------\
\
        function buildDataEngine() \{\
            let tempDataset = \{\};\
            let tempQuarters = [];\
            \
            // Initialize structures\
            [...councils, "Northern Ireland Average"].forEach(c => \{\
                tempDataset[c] = \{\
                    all: [], detached: [], "semi-detached": [], terraced: [], apartment: []\
                \};\
            \});\
\
            // Populate 2016 Q1 through 2026 Q1\
            for (let year = 2016; year <= 2026; year++) \{\
                let maxQ = (year === 2026) ? 1 : 4; \
                for (let q = 1; q <= maxQ; q++) \{\
                    let quarterStr = `$\{year\} Q$\{q\}`;\
                    tempQuarters.push(quarterStr);\
\
                    let timeFactor = (year - 2016) + (q/4);\
                    // Standard historic growth simulation curve\
                    let marketModifier = 1.0;\
                    if (year === 2020) marketModifier = 0.97; // Covid shock dip\
                    if (year === 2021 || year === 2022) marketModifier = 1.09; // Pandemic bounce surge\
\
                    [...councils, "Northern Ireland Average"].forEach(council => \{\
                        let base = basePrices[council];\
                        let growth = Math.pow(1.042, timeFactor) * marketModifier; \
                        \
                        // Seed specific pseudo-randomness per council area to represent authentic divergence\
                        let seed = (council.charCodeAt(0) + council.charCodeAt(council.length-1)) / 200;\
                        let localNoise = 1 + (Math.sin(timeFactor + seed) * 0.025);\
\
                        // Generate trends across all types\
                        Object.keys(propertyTypeRatios).forEach(type => \{\
                            let typeMultiplier = propertyTypeRatios[type];\
                            // Detached has slightly higher growth, apartments have slower growth\
                            let typeGrowthTuning = 1.0;\
                            if (type === 'detached') typeGrowthTuning = 1 + (timeFactor * 0.005);\
                            if (type === 'apartment') typeGrowthTuning = 1 - (timeFactor * 0.008);\
\
                            let finalBasePrice = Math.round(base * typeMultiplier * growth * localNoise * typeGrowthTuning);\
                            tempDataset[council][type].push(\{\
                                quarter: quarterStr,\
                                price: finalBasePrice,\
                                year: year.toString()\
                            \});\
                        \});\
                    \});\
                \}\
            \}\
            dataset = tempDataset;\
            quarters = tempQuarters;\
        \}\
\
        // ------------------------------------------------------------------------\
        // 3. Financial Helper Calculations (Index, Median, QoQ, YoY, Inflation Adjustments)\
        // ------------------------------------------------------------------------\
\
        function getValueForPoint(council, type, index, metricValue = selectedMetric) \{\
            const dataArr = dataset[council][type];\
            if (!dataArr[index]) return 0;\
\
            const baseItem = dataArr[index];\
            let targetPrice = baseItem.price;\
\
            // Apply Inflation conversion if toggled\
            if (isInflationAdjusted) \{\
                let cpiMult = cpiAdjustments[baseItem.year] || 1.00;\
                targetPrice = Math.round(targetPrice * cpiMult);\
            \}\
\
            if (metricValue === 'price') \{\
                return targetPrice;\
            \} else if (metricValue === 'median') \{\
                // Median is typically ~88-92% of the average due to high-end outliers skewing the average. We estimate at 89%.\
                return Math.round(targetPrice * 0.89);\
            \} else if (metricValue === 'index') \{\
                // Base Index reference is Q1 2016 (index 0)\
                let initialPoint = dataArr[0].price;\
                if (isInflationAdjusted) \{\
                    initialPoint = Math.round(initialPoint * cpiAdjustments["2016"]);\
                \}\
                return parseFloat(((targetPrice / initialPoint) * 100).toFixed(1));\
            \} else if (metricValue === 'qoq') \{\
                if (index === 0) return 0;\
                let prevVal = dataArr[index - 1].price;\
                if (isInflationAdjusted) \{\
                    prevVal = Math.round(prevVal * (cpiAdjustments[dataArr[index - 1].year] || 1.00));\
                \}\
                let change = ((targetPrice - prevVal) / prevVal) * 100;\
                return parseFloat(change.toFixed(2));\
            \} else if (metricValue === 'yoy') \{\
                if (index < 4) return 0; // Requires trailing year data\
                let prevYearVal = dataArr[index - 4].price;\
                if (isInflationAdjusted) \{\
                    prevYearVal = Math.round(prevYearVal * (cpiAdjustments[dataArr[index - 4].year] || 1.00));\
                \}\
                let change = ((targetPrice - prevYearVal) / prevYearVal) * 100;\
                return parseFloat(change.toFixed(2));\
            \}\
            return 0;\
        \}\
\
        // Standard financial formatters\
        const formatMoney = (amount) => \{\
            return new Intl.NumberFormat('en-GB', \{ style: 'currency', currency: 'GBP', maximumFractionDigits: 0 \}).format(amount);\
        \};\
\
        const formatPercent = (val) => \{\
            return (val >= 0 ? '+' : '') + val.toFixed(1) + '%';\
        \};\
\
        // ------------------------------------------------------------------------\
        // 4. UI Rendering and DOM Interactions\
        // ------------------------------------------------------------------------\
\
        function initSidebarFilters() \{\
            // Build Council Comparison Checkboxes\
            const listContainer = document.getElementById('council-list');\
            listContainer.innerHTML = '';\
            \
            // NI Average Checkbox option\
            listContainer.innerHTML += createCheckboxRow("Northern Ireland Average", true);\
\
            // Sorted LGDs list\
            councils.slice().sort().forEach(council => \{\
                let isChecked = selectedCouncils.includes(council);\
                listContainer.innerHTML += createCheckboxRow(council, isChecked);\
            \});\
\
            // Build Property Type Selection segmented buttons\
            const propButtons = document.getElementById('property-type-buttons');\
            propButtons.innerHTML = '';\
            const types = [\
                \{ id: "all", label: "All Properties" \},\
                \{ id: "detached", label: "Detached" \},\
                \{ id: "semi-detached", label: "Semi-Det." \},\
                \{ id: "terraced", label: "Terraced" \},\
                \{ id: "apartment", label: "Apartments" \}\
            ];\
\
            types.forEach(t => \{\
                const isActive = selectedPropertyType === t.id;\
                propButtons.innerHTML += `\
                    <button onclick="setPropertyType('$\{t.id\}')" id="propBtn-$\{t.id\}" class="text-[11px] py-1.5 px-2 rounded-lg font-bold border transition-all $\{\
                        isActive \
                        ? 'bg-blue-600/20 text-blue-400 border-blue-500/40 shadow-inner' \
                        : 'bg-slate-950 text-slate-400 border-slate-800 hover:text-white hover:border-slate-700'\
                    \}">$\{t.label\}</button>\
                `;\
            \});\
        \}\
\
        function createCheckboxRow(label, isChecked) \{\
            const safeId = label.replace(/\\s+/g, '');\
            return `\
                <label class="flex items-center justify-between p-2 rounded-lg bg-slate-950/60 hover:bg-slate-800/40 border $\{isChecked ? 'border-blue-500/30' : 'border-slate-800'\} cursor-pointer transition-all mb-1" id="lbl-$\{safeId\}">\
                    <div class="flex items-center gap-2">\
                        <input type="checkbox" name="councilCheck" value="$\{label\}" $\{isChecked ? 'checked' : ''\} onchange="toggleCouncilSelection(this)" class="w-3.5 h-3.5 text-blue-600 bg-slate-950 border-slate-700 rounded focus:ring-blue-500">\
                        <span class="text-xs $\{isChecked ? 'text-white font-semibold' : 'text-slate-400'\}">$\{label === "Northern Ireland Average" ? '\uc0\u55357 \u56522  NI Avg' : label\}</span>\
                    </div>\
                </label>\
            `;\
        \}\
\
        function toggleCouncilSelection(checkbox) \{\
            const council = checkbox.value;\
            const safeId = council.replace(/\\s+/g, '');\
            const labelEl = document.getElementById(`lbl-$\{safeId\}`);\
\
            if (checkbox.checked) \{\
                if (!selectedCouncils.includes(council)) \{\
                    selectedCouncils.push(council);\
                \}\
                labelEl.classList.remove('border-slate-800');\
                labelEl.classList.add('border-blue-500/30');\
                labelEl.querySelector('span').classList.add('text-white', 'font-semibold');\
            \} else \{\
                selectedCouncils = selectedCouncils.filter(c => c !== council);\
                labelEl.classList.remove('border-blue-500/30');\
                labelEl.classList.add('border-slate-800');\
                labelEl.querySelector('span').classList.remove('text-white', 'font-semibold');\
            \}\
            updateDashboard();\
        \}\
\
        function clearAllCouncils() \{\
            selectedCouncils = [];\
            document.querySelectorAll('input[name="councilCheck"]').forEach(cb => \{\
                cb.checked = false;\
                const safeId = cb.value.replace(/\\s+/g, '');\
                const labelEl = document.getElementById(`lbl-$\{safeId\}`);\
                labelEl.classList.remove('border-blue-500/30');\
                labelEl.classList.add('border-slate-800');\
                labelEl.querySelector('span').classList.remove('text-white', 'font-semibold');\
            \});\
            updateDashboard();\
        \}\
\
        function setPropertyType(type) \{\
            selectedPropertyType = type;\
            initSidebarFilters();\
            updateDashboard();\
        \}\
\
        function setMetric(metric) \{\
            selectedMetric = metric;\
            updateDashboard();\
        \}\
\
        function setInflationMode(mode) \{\
            isInflationAdjusted = mode;\
            \
            const btnNominal = document.getElementById('toggleNominal');\
            const btnReal = document.getElementById('toggleReal');\
\
            if (mode) \{\
                btnReal.className = "px-3 py-1 rounded-lg text-xs font-bold transition-all bg-amber-600 text-white shadow";\
                btnNominal.className = "px-3 py-1 rounded-lg text-xs font-bold transition-all text-slate-400 hover:text-white";\
                addConsoleLog("SYSTEM", "Currency calculation mode toggled to 'Real (Adjusted to Q1 2026 Buying Power)'.");\
            \} else \{\
                btnNominal.className = "px-3 py-1 rounded-lg text-xs font-bold transition-all bg-blue-600 text-white shadow";\
                btnReal.className = "px-3 py-1 rounded-lg text-xs font-bold transition-all text-slate-400 hover:text-white";\
                addConsoleLog("SYSTEM", "Currency calculation mode toggled to 'Nominal (Original pounds)'.");\
            \}\
            updateDashboard();\
        \}\
\
        function setTimeRange(years) \{\
            activeTimeHorizon = years;\
            ['time3', 'time5', 'time10'].forEach(id => \{\
                const btn = document.getElementById(id);\
                if (id === `time$\{years\}`) \{\
                    btn.className = "text-xs py-1 rounded font-semibold bg-blue-600 text-white shadow";\
                \} else \{\
                    btn.className = "text-xs py-1 rounded font-semibold text-slate-400 hover:text-white";\
                \}\
            \});\
            updateDashboard();\
        \}\
\
        // ------------------------------------------------------------------------\
        // 5. Dashboard Core Refresh & Chart Implementations\
        // ------------------------------------------------------------------------\
\
        function updateDashboard() \{\
            // 1. Filter Quarters range based on activeTimeHorizon (4 quarters per year)\
            const countToDisplay = activeTimeHorizon * 4;\
            const displayedQuarters = quarters.slice(-countToDisplay);\
            const startIndex = quarters.length - displayedQuarters.length;\
\
            const latestIdx = quarters.length - 1;\
            const previousQtrIdx = latestIdx - 1;\
            const latestQuarterName = quarters[latestIdx];\
\
            // Update Latest Quarter badge\
            document.getElementById('latest-qtr-badge').innerText = `Quarter: $\{latestQuarterName\}`;\
\
            // 2. Perform KPI Stats calculations\
            const niLatestPrice = getValueForPoint("Northern Ireland Average", selectedPropertyType, latestIdx, 'price');\
            const niPrevPrice = getValueForPoint("Northern Ireland Average", selectedPropertyType, previousQtrIdx, 'price');\
            const niQoqPrice = getValueForPoint("Northern Ireland Average", selectedPropertyType, latestIdx, 'qoq');\
\
            // KPI 1 - NI National Average\
            document.getElementById('kpi1-value').innerText = formatMoney(niLatestPrice);\
            document.getElementById('kpi1-title').innerText = `NI AVG ($\{latestQuarterName\})`;\
            document.getElementById('kpi1-adj').innerText = isInflationAdjusted ? "Real (2026)" : "Nominal";\
            \
            const kpi1Sub = document.getElementById('kpi1-sub');\
            const colorClass = niQoqPrice >= 0 ? 'text-emerald-400' : 'text-rose-400';\
            const sign = niQoqPrice >= 0 ? '\uc0\u9650 ' : '\u9660 ';\
            kpi1Sub.innerHTML = `<span class="$\{colorClass\} font-bold text-xs flex items-center gap-1">$\{sign\} $\{Math.abs(niQoqPrice).toFixed(1)\}% QoQ</span> <span class="text-[10px] text-slate-500">Prev Qtr: $\{formatMoney(niPrevPrice)\}</span>`;\
\
            // KPI 2 - Selected Council Highest / Max\
            if (selectedCouncils.length > 0) \{\
                let maxVal = 0;\
                let topLgd = "";\
                selectedCouncils.forEach(c => \{\
                    let val = getValueForPoint(c, selectedPropertyType, latestIdx, 'price');\
                    if (val > maxVal) \{\
                        maxVal = val;\
                        topLgd = c;\
                    \}\
                \});\
                document.getElementById('kpi2-value').innerText = formatMoney(maxVal);\
                document.getElementById('kpi2-sub').innerText = `$\{topLgd || "All select"\}`;\
            \} else \{\
                document.getElementById('kpi2-value').innerText = "\'a30";\
                document.getElementById('kpi2-sub').innerText = "Select councils to measure";\
            \}\
\
            // Update synchronized quarter counter KPI 4\
            document.getElementById('kpi4-value').innerText = quarters.length;\
            document.getElementById('kpi4-sub').innerText = `$\{quarters[0]\} to $\{quarters[quarters.length - 1]\}`;\
\
            // 3. Render and Synchronize Charts\
            renderTrendChart(displayedQuarters, startIndex);\
            renderPropertyDistribution(latestIdx);\
            renderRegionalBarChart(latestIdx);\
\
            // 4. Populate table\
            renderDataTable();\
        \}\
\
        function renderTrendChart(displayedQuarters, startIndex) \{\
            const ctx = document.getElementById('mainTrendChart').getContext('2d');\
            \
            // Build dataset array based on selection\
            const chartDatasets = selectedCouncils.map((council, idx) => \{\
                const colorPalette = [\
                    '#3b82f6', '#10b981', '#f59e0b', '#ec4899', '#8b5cf6', \
                    '#06b6d4', '#f97316', '#a855f7', '#14b8a6', '#f43f5e'\
                ];\
                const color = colorPalette[idx % colorPalette.length];\
\
                const values = quarters.slice(startIndex).map((q, qIdx) => \{\
                    return getValueForPoint(council, selectedPropertyType, startIndex + qIdx);\
                \});\
\
                return \{\
                    label: council,\
                    data: values,\
                    borderColor: color,\
                    backgroundColor: `$\{color\}15`,\
                    borderWidth: 2.5,\
                    fill: selectedCouncils.length === 1, // Only fill if solitary council selected\
                    tension: 0.25,\
                    pointRadius: selectedCouncils.length > 4 ? 0 : 2,\
                    pointHoverRadius: 6\
                \};\
            \});\
\
            // Fallback default lines if none selected\
            if (chartDatasets.length === 0) \{\
                chartDatasets.push(\{\
                    label: "No Area Selected",\
                    data: displayedQuarters.map(() => 0),\
                    borderColor: '#475569',\
                    borderWidth: 1,\
                    borderDash: [5, 5]\
                \});\
            \}\
\
            if (trendChartInstance) \{\
                trendChartInstance.destroy();\
            \}\
\
            // Format axis prefixes based on metric\
            let yTicksCallback = (value) => value;\
            if (selectedMetric === 'price' || selectedMetric === 'median') \{\
                yTicksCallback = (value) => '\'a3' + (value / 1000) + 'k';\
            \} else if (selectedMetric === 'index') \{\
                yTicksCallback = (value) => value + '%';\
            \} else \{\
                yTicksCallback = (value) => value + '%';\
            \}\
\
            trendChartInstance = new Chart(ctx, \{\
                type: 'line',\
                data: \{\
                    labels: displayedQuarters,\
                    datasets: chartDatasets\
                \},\
                options: \{\
                    responsive: true,\
                    maintainAspectRatio: false,\
                    interaction: \{\
                        mode: 'index',\
                        intersect: false\
                    \},\
                    plugins: \{\
                        legend: \{\
                            display: false // We use our custom legend builder below\
                        \},\
                        tooltip: \{\
                            backgroundColor: '#0f172a',\
                            titleColor: '#f8fafc',\
                            bodyColor: '#cbd5e1',\
                            borderColor: '#334155',\
                            borderWidth: 1,\
                            padding: 10,\
                            callbacks: \{\
                                label: function(context) \{\
                                    let label = context.dataset.label || '';\
                                    if (label) \{\
                                        label += ': ';\
                                    \}\
                                    if (selectedMetric === 'price' || selectedMetric === 'median') \{\
                                        label += formatMoney(context.parsed.y);\
                                    \} else if (selectedMetric === 'index') \{\
                                        label += context.parsed.y + ' (Index)';\
                                    \} else \{\
                                        label += formatPercent(context.parsed.y);\
                                    \}\
                                    return label;\
                                \}\
                            \}\
                        \}\
                    \},\
                    scales: \{\
                        y: \{\
                            grid: \{ color: '#1e293b', borderDash: [3, 3] \},\
                            ticks: \{ color: '#94a3b8', font: \{ size: 10 \}, callback: yTicksCallback \}\
                        \},\
                        x: \{\
                            grid: \{ display: false \},\
                            ticks: \{ color: '#94a3b8', font: \{ size: 9 \}, maxRotation: 45, minRotation: 45 \}\
                        \}\
                    \}\
                \}\
            \});\
\
            // Update Chart Custom HTML Legend\
            const legendDiv = document.getElementById('chart-legend');\
            legendDiv.innerHTML = '';\
            chartDatasets.forEach((dataset, i) => \{\
                if (dataset.label === "No Area Selected") return;\
                legendDiv.innerHTML += `\
                    <div class="flex items-center gap-1.5 bg-slate-800/60 px-2 py-0.5 rounded-md border border-slate-700/60 text-[10px] font-bold text-slate-300">\
                        <span class="w-2 h-2 rounded-full inline-block" style="background-color: $\{dataset.borderColor\}"></span>\
                        $\{dataset.label\}\
                    </div>\
                `;\
            \});\
        \}\
\
        function renderPropertyDistribution(latestIdx) \{\
            const ctx = document.getElementById('propertyDistributionChart').getContext('2d');\
            \
            // Collect the first selected council or fall back to NI Average\
            const focusCouncil = selectedCouncils.length > 0 ? selectedCouncils[0] : "Northern Ireland Average";\
            \
            const categories = ["detached", "semi-detached", "terraced", "apartment"];\
            const labels = ["Detached", "Semi-Detached", "Terraced", "Apartment"];\
            \
            const rawValues = categories.map(cat => \{\
                return getValueForPoint(focusCouncil, cat, latestIdx, 'price');\
            \});\
\
            if (propertyDistChartInstance) \{\
                propertyDistChartInstance.destroy();\
            \}\
\
            propertyDistChartInstance = new Chart(ctx, \{\
                type: 'radar',\
                data: \{\
                    labels: labels,\
                    datasets: [\{\
                        label: `$\{focusCouncil\} (Latest)`,\
                        data: rawValues,\
                        backgroundColor: 'rgba(59, 130, 246, 0.2)',\
                        borderColor: '#3b82f6',\
                        borderWidth: 2,\
                        pointBackgroundColor: '#3b82f6',\
                        pointBorderColor: '#fff',\
                        pointHoverBackgroundColor: '#fff',\
                        pointHoverBorderColor: '#3b82f6'\
                    \}]\
                \},\
                options: \{\
                    responsive: true,\
                    maintainAspectRatio: false,\
                    plugins: \{\
                        legend: \{ display: false \},\
                        tooltip: \{\
                            backgroundColor: '#0f172a',\
                            callbacks: \{\
                                label: function(context) \{\
                                    return context.label + ': ' + formatMoney(context.parsed.y);\
                                \}\
                            \}\
                        \}\
                    \},\
                    scales: \{\
                        r: \{\
                            angleLines: \{ color: '#1e293b' \},\
                            grid: \{ color: '#1e293b' \},\
                            pointLabels: \{ color: '#94a3b8', font: \{ size: 9, weight: 'bold' \} \},\
                            ticks: \{ \
                                display: false,\
                                color: '#475569' \
                            \}\
                        \}\
                    \}\
                \}\
            \});\
        \}\
\
        function renderRegionalBarChart(latestIdx) \{\
            const ctx = document.getElementById('regionalBarChart').getContext('2d');\
            \
            // Collect latest quarter metrics across ALL 11 councils\
            const datasetValues = councils.map(lgd => \{\
                return \{\
                    name: lgd,\
                    value: getValueForPoint(lgd, selectedPropertyType, latestIdx)\
                \};\
            \});\
\
            // Sort councils descending based on active metric performance\
            datasetValues.sort((a, b) => b.value - a.value);\
\
            const colors = datasetValues.map(item => \{\
                return selectedCouncils.includes(item.name) ? '#3b82f6' : '#1e293b';\
            \});\
            const borderColors = datasetValues.map(item => \{\
                return selectedCouncils.includes(item.name) ? '#60a5fa' : '#334155';\
            \});\
\
            if (regionalChartInstance) \{\
                regionalChartInstance.destroy();\
            \}\
\
            let tooltipCallback = (context) => context.parsed.x;\
            if (selectedMetric === 'price' || selectedMetric === 'median') \{\
                tooltipCallback = (context) => formatMoney(context.parsed.x);\
            \} else if (selectedMetric === 'index') \{\
                tooltipCallback = (context) => context.parsed.x + ' (Index)';\
            \} else \{\
                tooltipCallback = (context) => formatPercent(context.parsed.x);\
            \}\
\
            regionalChartInstance = new Chart(ctx, \{\
                type: 'bar',\
                data: \{\
                    labels: datasetValues.map(item => item.name),\
                    datasets: [\{\
                        data: datasetValues.map(item => item.value),\
                        backgroundColor: colors,\
                        borderColor: borderColors,\
                        borderWidth: 1,\
                        borderRadius: 4\
                    \}]\
                \},\
                options: \{\
                    indexAxis: 'y',\
                    responsive: true,\
                    maintainAspectRatio: false,\
                    plugins: \{\
                        legend: \{ display: false \},\
                        tooltip: \{\
                            backgroundColor: '#0f172a',\
                            callbacks: \{\
                                label: tooltipCallback\
                            \}\
                        \}\
                    \},\
                    scales: \{\
                        x: \{\
                            grid: \{ color: '#1e293b' \},\
                            ticks: \{ \
                                color: '#94a3b8', \
                                font: \{ size: 9 \},\
                                callback: function(value) \{\
                                    if (selectedMetric === 'price' || selectedMetric === 'median') \{\
                                        return '\'a3' + (value/1000) + 'k';\
                                    \}\
                                    return value;\
                                \}\
                            \}\
                        \},\
                        y: \{\
                            grid: \{ display: false \},\
                            ticks: \{ color: '#cbd5e1', font: \{ size: 9, weight: 'medium' \} \}\
                        \}\
                    \}\
                \}\
            \});\
        \}\
\
        function renderDataTable() \{\
            const headerRow = document.getElementById('tableHeader');\
            const bodyRow = document.getElementById('tableBody');\
            const searchVal = document.getElementById('searchTable').value.toLowerCase();\
\
            // Setup Header Columns based on selection\
            let cols = ["Quarter", "NI Average"];\
            selectedCouncils.forEach(c => \{\
                if (c !== "Northern Ireland Average") \{\
                    cols.push(c);\
                \}\
            \});\
\
            headerRow.innerHTML = cols.map(c => `<th class="px-5 py-3 font-semibold text-[11px] tracking-wider border-b border-slate-800">$\{c\}</th>`).join('');\
\
            // Setup Rows descending by quarter\
            let tableHTML = "";\
            \
            for (let idx = quarters.length - 1; idx >= 0; idx--) \{\
                const qName = quarters[idx];\
                if (searchVal && !qName.toLowerCase().includes(searchVal)) continue;\
\
                let rowHTML = `<td class="px-5 py-3 font-semibold text-slate-100">$\{qName\}</td>`;\
                \
                // NI Value column\
                let niVal = getValueForPoint("Northern Ireland Average", selectedPropertyType, idx);\
                let niFormatted = (selectedMetric === 'price' || selectedMetric === 'median') ? formatMoney(niVal) : (selectedMetric === 'index' ? niVal : niVal.toFixed(2) + '%');\
                rowHTML += `<td class="px-5 py-3 text-slate-400 font-medium">$\{niFormatted\}</td>`;\
\
                // Selected comparison councils columns\
                selectedCouncils.forEach(c => \{\
                    if (c !== "Northern Ireland Average") \{\
                        let lValue = getValueForPoint(c, selectedPropertyType, idx);\
                        let formatted = (selectedMetric === 'price' || selectedMetric === 'median') ? formatMoney(lValue) : (selectedMetric === 'index' ? lValue : lValue.toFixed(2) + '%');\
                        rowHTML += `<td class="px-5 py-3 font-medium text-slate-300">$\{formatted\}</td>`;\
                    \}\
                \});\
\
                tableHTML += `<tr class="hover:bg-slate-900/40 border-b border-slate-800/60">$\{rowHTML\}</tr>`;\
            \}\
\
            bodyRow.innerHTML = tableHTML || `<tr><td colspan="$\{cols.length\}" class="px-5 py-4 text-center text-slate-500">No matching quarters found.</td></tr>`;\
        \}\
\
        function exportToCSV() \{\
            let cols = ["Quarter", "Northern Ireland Average"];\
            selectedCouncils.forEach(c => \{\
                if (c !== "Northern Ireland Average") cols.push(c);\
            \});\
\
            let csvContent = "data:text/csv;charset=utf-8," + cols.join(",") + "\\n";\
\
            for (let idx = quarters.length - 1; idx >= 0; idx--) \{\
                let row = [quarters[idx]];\
                let niVal = getValueForPoint("Northern Ireland Average", selectedPropertyType, idx);\
                row.push(niVal);\
\
                selectedCouncils.forEach(c => \{\
                    if (c !== "Northern Ireland Average") \{\
                        row.push(getValueForPoint(c, selectedPropertyType, idx));\
                    \}\
                \});\
                csvContent += row.join(",") + "\\n";\
            \}\
\
            const encodedUri = encodeURI(csvContent);\
            const link = document.createElement("a");\
            link.setAttribute("href", encodedUri);\
            link.setAttribute("download", `ni_house_prices_$\{selectedMetric\}_$\{selectedPropertyType\}.csv`);\
            document.body.appendChild(link);\
            link.click();\
            document.body.removeChild(link);\
            addConsoleLog("SYSTEM", "CSV Export triggered and downloaded successfully.");\
        \}\
\
        // ------------------------------------------------------------------------\
        // 6. Interactive Developer Console & API Engine Integration Simulation\
        // ------------------------------------------------------------------------\
\
        function openConsole() \{\
            document.getElementById('apiConsoleModal').classList.remove('hidden');\
            addConsoleLog("DEBUG", "Opened Developer API Integration Console.");\
        \}\
\
        function closeConsole() \{\
            document.getElementById('apiConsoleModal').classList.add('hidden');\
        \}\
\
        function addConsoleLog(type, message) \{\
            const container = document.getElementById('terminal-logs');\
            const timeStr = new Date().toLocaleTimeString();\
            \
            let typeColor = "text-slate-400";\
            if (type === "SYSTEM") typeColor = "text-blue-400 font-semibold";\
            if (type === "SUCCESS") typeColor = "text-emerald-400 font-semibold";\
            if (type === "ERROR") typeColor = "text-rose-400 font-semibold";\
            if (type === "JSON") typeColor = "text-purple-400";\
\
            container.innerHTML += `\
                <div class="border-b border-slate-800/40 pb-1 flex flex-col sm:flex-row sm:items-baseline gap-2">\
                    <span class="text-[10px] text-slate-500 select-none">[$\{timeStr\}]</span>\
                    <span class="text-[11px] $\{typeColor\} uppercase select-none">[$\{type\}]</span>\
                    <span class="text-[11px] font-medium text-slate-200">$\{message\}</span>\
                </div>\
            `;\
            // Autoscroll to bottom\
            container.scrollTop = container.scrollHeight;\
        \}\
\
        function clearConsoleLogs() \{\
            document.getElementById('terminal-logs').innerHTML = `<div class="text-slate-500">// Terminal logs cleared. Ready...</div>`;\
        \}\
\
        function triggerAPIDownload() \{\
            addConsoleLog("SYSTEM", "Querying endpoint: GET https://admin.opendatani.gov.uk/api/3/action/package_show?id=nihpi-by-propertytype");\
            addConsoleLog("DEBUG", "Initiating Secure Handshake TLS v1.3. Headers: \{ Accept: 'application/json' \}");\
            \
            setTimeout(() => \{\
                addConsoleLog("SUCCESS", "CKAN Response Code: 200 OK. Standardised database detected on host server.");\
                \
                // Append Q2 2026 data if not already exists\
                const newQuarter = "2026 Q2";\
                if (quarters.includes(newQuarter)) \{\
                    addConsoleLog("SYSTEM", "Synchronizer verification: local repository already fully updated to the latest standard.");\
                \} else \{\
                    quarters.push(newQuarter);\
                    \
                    // Simulate upward / realistic movement\
                    Object.keys(dataset).forEach(lgd => \{\
                        Object.keys(propertyTypeRatios).forEach(type => \{\
                            const lastIdx = dataset[lgd][type].length - 1;\
                            const prevPrice = dataset[lgd][type][lastIdx].price;\
                            \
                            // Average nominal increase of ~1.2% for the new quarter\
                            const randomJump = 1 + ((Math.random() - 0.2) * 0.03); \
                            const finalPrice = Math.round(prevPrice * randomJump);\
\
                            dataset[lgd][type].push(\{\
                                quarter: newQuarter,\
                                price: finalPrice,\
                                year: "2026"\
                            \});\
                        \});\
                    \});\
\
                    // Disable notification bar\
                    document.getElementById('newReleaseNotification').classList.add('hidden');\
                    newReleasePending = false;\
\
                    addConsoleLog("SUCCESS", `Database update finalized. Q2 2026 dataset merged successfully. Added $\{councils.length + 1\} series.`);\
                \}\
\
                // Show dynamic raw sample response\
                addConsoleLog("JSON", JSON.stringify(\{\
                    success: true,\
                    result: \{\
                        id: "nihpi-by-propertytype",\
                        title: "NI House Price Index by Property Type",\
                        resources: [\
                            \{ format: "CSV", url: "https://admin.opendatani.gov.uk/dataset/.../standardised-price-by-lgd-q2-2026.csv", size: "7.4 KB" \}\
                        ],\
                        metadata_modified: "2026-05-18T14:45:00Z"\
                    \}\
                \}, null, 2));\
\
                // Redraw\
                updateDashboard();\
\
                // Create success banner feedback\
                const notification = document.createElement('div');\
                notification.className = "fixed bottom-5 right-5 bg-emerald-600 text-white font-bold text-xs py-2 px-4 rounded-xl shadow-lg shadow-emerald-950/30 z-50 transition-all duration-500 flex items-center gap-2";\
                notification.innerHTML = `\
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>\
                    Fetched Q2 2026 from OpenDataNI Endpoint!\
                `;\
                document.body.appendChild(notification);\
                setTimeout(() => \{\
                    notification.style.opacity = '0';\
                    setTimeout(() => notification.remove(), 500);\
                \}, 3500);\
\
            \}, 1200);\
        \}\
\
        function triggerAPIError() \{\
            addConsoleLog("SYSTEM", "Querying endpoint: GET https://admin.opendatani.gov.uk/api/3/action/package_show?id=nihpi-by-propertytype");\
            addConsoleLog("DEBUG", "Connecting to 194.80.3.11...");\
            \
            setTimeout(() => \{\
                addConsoleLog("ERROR", "Connection closed by foreign host. HTTP STATUS: 504 Gateway Timeout.");\
                addConsoleLog("SYSTEM", "Failsafe deployed: Loading cached local replica database context to prevent application termination.");\
                \
                // Show red warning banner feedback\
                const notification = document.createElement('div');\
                notification.className = "fixed bottom-5 right-5 bg-rose-600 text-white font-bold text-xs py-2 px-4 rounded-xl shadow-lg shadow-rose-950/30 z-50 transition-all duration-500 flex items-center gap-2";\
                notification.innerHTML = `\
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>\
                    API Endpoint connection timed out. Using sandbox offline mode.\
                `;\
                document.body.appendChild(notification);\
                setTimeout(() => \{\
                    notification.style.opacity = '0';\
                    setTimeout(() => notification.remove(), 500);\
                \}, 4000);\
            \}, 1000);\
        \}\
\
        // Trigger the simulation alert after 4 seconds to educate user about the active scheduler\
        function setupLiveNotificationScheduler() \{\
            setTimeout(() => \{\
                if (newReleasePending) \{\
                    document.getElementById('newReleaseNotification').classList.remove('hidden');\
                \}\
            \}, 2500);\
        \}\
\
        // ------------------------------------------------------------------------\
        // 7. Initialize Application\
        // ------------------------------------------------------------------------\
        window.onload = function() \{\
            buildDataEngine();\
            initSidebarFilters();\
            updateDashboard();\
            setupLiveNotificationScheduler();\
            addConsoleLog("SYSTEM", "Sandbox initialized. 10 years of historical data parsed correctly.");\
        \};\
    </script>\
